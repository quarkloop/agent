# syntax=docker/dockerfile:1.7

ARG GO_VERSION=1.26

FROM golang:${GO_VERSION}-alpine AS build
WORKDIR /src
RUN apk add --no-cache ca-certificates git
COPY . .
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/quark ./services/devops/cmd/devops

# DevOps functions execute supported build/test/container adapters in-process.
# Their execution image must contain the corresponding clients and toolchain.
FROM golang:${GO_VERSION}-alpine
RUN addgroup -S quark && adduser -S -G quark quark && \
    apk add --no-cache ca-certificates curl docker-cli git tzdata
# Compose may run this image under the bind-mounted workspace owner's UID.
# Keep execution caches ephemeral and writable without mutating that workspace.
ENV HOME=/tmp/quark-devops/home \
    GOPATH=/tmp/quark-devops/go \
    GOMODCACHE=/tmp/quark-devops/go/pkg/mod \
    GOCACHE=/tmp/quark-devops/go-build
USER quark
WORKDIR /var/lib/quark
COPY --from=build /out/quark /usr/local/bin/quark
ENTRYPOINT ["/usr/local/bin/quark"]
