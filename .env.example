# Gateway provider credentials. Space model selection is persisted in space.json.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Web search (optional — stub response returned if absent)
BRAVE_API_KEY=
SERPAPI_KEY=

# Provider-backed E2E uses OpenRouter and permits only its declared test models.
# OPENROUTER_E2E_MODEL=openrouter/owl-alpha
# OPENROUTER_E2E_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# QUARK_E2E_MAX_PROVIDER_REQUESTS=20

# Local NATS control-plane connection for CLI commands.
# QUARK_NATS_URL=nats://127.0.0.1:4222
# QUARK_NATS_USER=quark-control
# QUARK_NATS_PASSWORD=quark-control-dev
